# Copy this file to .env and fill in your values.
# The app loads these automatically via pydantic-settings.

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Get this from: Azure portal → Storage Account → Access keys → Connection string
# Or: az storage account show-connection-string --name <SA_NAME> --resource-group <RG>
AZURE_STORAGE_CONNECTION_STRING=

# The blob container name (created by the provisioning script below)
AZURE_STORAGE_CONTAINER=models

# ── Azure ML (optional — only needed for MLflow / model registry integration) ─
AZURE_ML_WORKSPACE=
AZURE_ML_RESOURCE_GROUP=
AZURE_ML_SUBSCRIPTION_ID=

# ── Model artifact names (must match what was saved) ─────────────────────────
REGRESSION_MODEL_NAME=regression
CLASSIFICATION_MODEL_NAME=classification

# ── Local fallback: training from CSV when no pre-trained model is available ──
# Set these if you want the API to train on startup instead of loading a blob
TRAIN_DATA_PATH=
TEST_DATA_PATH=

# ── Local model cache directory (joblib files) ───────────────────────────────
MODEL_DIR=models

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
